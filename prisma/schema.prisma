generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgres"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  nickname  String
  createdAt DateTime @default(now())
  threads   Thread[]
}

model Thread {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id])
  createdAt DateTime  @default(now())
  messages  Message[]
}

model Message {
  id          String    @id @default(cuid())
  threadId    String
  thread      Thread    @relation(fields: [threadId], references: [id])
  sender      String    // "user" or "admin"
  content     String
  type        String    @default("normal") // "normal" or "confession"
  reaction    String?   // emoji reaction from admin
  scheduledAt DateTime?
  createdAt   DateTime  @default(now())
}
